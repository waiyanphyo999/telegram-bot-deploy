#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@zenuml/core/3.50.1/6ca8bcdbb7191da53cc46b31a9b9e1df17ada3880b9c74678c07d27721ef17c6/node_modules/@zenuml/core/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@zenuml/core/3.50.1/6ca8bcdbb7191da53cc46b31a9b9e1df17ada3880b9c74678c07d27721ef17c6/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb0f64-c48d254efbce5e23/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@zenuml/core/3.50.1/6ca8bcdbb7191da53cc46b31a9b9e1df17ada3880b9c74678c07d27721ef17c6/node_modules/@zenuml/core/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@zenuml/core/3.50.1/6ca8bcdbb7191da53cc46b31a9b9e1df17ada3880b9c74678c07d27721ef17c6/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb0f64-c48d254efbce5e23/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/bun.exe" ]; then
  exec "$basedir/bun.exe"  "$basedir_win/../@zenuml/core/dist/cli/zenuml.mjs" "$@"
elif [ -x "$basedir/bun" ]; then
  exec "$basedir/bun"  "$basedir/../@zenuml/core/dist/cli/zenuml.mjs" "$@"
elif command -v bun >/dev/null 2>&1; then
  exec bun  "$basedir/../@zenuml/core/dist/cli/zenuml.mjs" "$@"
elif [ -n "$exe" ] && command -v bun.exe >/dev/null 2>&1; then
  exec bun.exe  "$basedir_win/../@zenuml/core/dist/cli/zenuml.mjs" "$@"
else
  exec bun  "$basedir/../@zenuml/core/dist/cli/zenuml.mjs" "$@"
fi
