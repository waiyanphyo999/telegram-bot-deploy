#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.1/0c14e994161ce3fa0df99b503b10fd13d4910c9beaaae799a9d06bb79b4a72fe/node_modules/uuid/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.1/0c14e994161ce3fa0df99b503b10fd13d4910c9beaaae799a9d06bb79b4a72fe/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb0f64-c48d254efbce5e23/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.1/0c14e994161ce3fa0df99b503b10fd13d4910c9beaaae799a9d06bb79b4a72fe/node_modules/uuid/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.1/0c14e994161ce3fa0df99b503b10fd13d4910c9beaaae799a9d06bb79b4a72fe/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb0f64-c48d254efbce5e23/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../uuid/dist-node/bin/uuid" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../uuid/dist-node/bin/uuid" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../uuid/dist-node/bin/uuid" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../uuid/dist-node/bin/uuid" "$@"
else
  exec node  "$basedir/../uuid/dist-node/bin/uuid" "$@"
fi
