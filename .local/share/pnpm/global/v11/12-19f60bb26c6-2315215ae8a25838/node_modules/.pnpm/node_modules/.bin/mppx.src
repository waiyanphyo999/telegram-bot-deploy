#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/mppx/0.6.16/53faa17c876dd2b8e5e770f9ac81f21ef580e976d9c94b7ed01b16cde828f81b/node_modules/mppx/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/mppx/0.6.16/53faa17c876dd2b8e5e770f9ac81f21ef580e976d9c94b7ed01b16cde828f81b/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb26c6-2315215ae8a25838/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/mppx/0.6.16/53faa17c876dd2b8e5e770f9ac81f21ef580e976d9c94b7ed01b16cde828f81b/node_modules/mppx/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/mppx/0.6.16/53faa17c876dd2b8e5e770f9ac81f21ef580e976d9c94b7ed01b16cde828f81b/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb26c6-2315215ae8a25838/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../mppx/src/bin.ts" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../mppx/src/bin.ts" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../mppx/src/bin.ts" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../mppx/src/bin.ts" "$@"
else
  exec node  "$basedir/../mppx/src/bin.ts" "$@"
fi
# cmd-shim-target=/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb26c6-2315215ae8a25838/node_modules/.pnpm/node_modules/mppx/src/bin.ts
