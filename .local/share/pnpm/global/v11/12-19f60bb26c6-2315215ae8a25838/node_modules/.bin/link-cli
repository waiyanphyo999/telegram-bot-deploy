fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../../../../../store/v11/links/@stripe/link-cli/0.8.3/7501378e836be1d785b179829866c58626470d4d7c5e3010d437c63c29611d24/node_modules/@stripe/link-cli/dist/cli.js" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../store/v11/links/@stripe/link-cli/0.8.3/7501378e836be1d785b179829866c58626470d4d7c5e3010d437c63c29611d24/node_modules/@stripe/link-cli/dist/cli.js" "$@"
elif command -v node >/dev/null 2>&1; then
