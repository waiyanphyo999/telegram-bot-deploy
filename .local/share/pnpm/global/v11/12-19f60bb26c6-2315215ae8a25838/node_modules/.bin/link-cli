elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../../../../../store/v11/links/@stripe/link-cli/0.8.3/7501378e836be1d785b179829866c58626470d4d7c5e3010d437c63c29611d24/node_modules/@stripe/link-cli/dist/cli.js" "$@"
else
