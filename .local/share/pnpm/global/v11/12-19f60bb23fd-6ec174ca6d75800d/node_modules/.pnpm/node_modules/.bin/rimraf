#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/d6fa78778f069bdc96cce02aaf99e6513abe372445bade86feb721ab3fbcb458/node_modules/rimraf/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/d6fa78778f069bdc96cce02aaf99e6513abe372445bade86feb721ab3fbcb458/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb23fd-6ec174ca6d75800d/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/d6fa78778f069bdc96cce02aaf99e6513abe372445bade86feb721ab3fbcb458/node_modules/rimraf/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/d6fa78778f069bdc96cce02aaf99e6513abe372445bade86feb721ab3fbcb458/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19f60bb23fd-6ec174ca6d75800d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../rimraf/dist/esm/bin.mjs" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../rimraf/dist/esm/bin.mjs" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../rimraf/dist/esm/bin.mjs" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../rimraf/dist/esm/bin.mjs" "$@"
else
  exec node  "$basedir/../rimraf/dist/esm/bin.mjs" "$@"
fi
